# Copy to `.env`, fill in, and keep out of git (already in .gitignore).
# scripts/daily_reports.sh sources this file automatically; for manual runs:
#     set -a; source .env; set +a

# Elasticsearch credentials (the only required secret)
TLSOC_ES_PASS=

# Optional overrides (defaults come from config/settings.yaml)
#TLSOC_ES_HOST=https://YOUR-ELK-HOST:9200
#TLSOC_ES_USER=elastic
#TLSOC_ES_CA_CERT=/opt/TLSOCDockerDeploy/certs/ca/ca.crt
#TLSOC_OUTPUT_HTML_DIR=
#TLSOC_OUTPUT_PDF_DIR=
